{
  "name": "@sandylib27/react-ag-datatable",
  "version": "0.1.0",
  "description": "Production-ready React DataTable wrapping AG Grid Community with enterprise-grade features: searchable set filters, number filters, column header menus, integrated pagination, API mode with loading states, and a classical theme.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "tsup && cp src/styles.css dist/styles.css",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "dev:examples": "vite --config examples/vite.config.ts"
  },
  "keywords": [
    "react",
    "ag-grid",
    "datatable",
    "data-grid",
    "table",
    "filter",
    "pagination",
    "set-filter",
    "number-filter",
    "column-menu",
    "shadcn",
    "radix-ui"
  ],
  "author": "sandylib27",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sandylib/react-ag-datatable"
  },
  "peerDependencies": {
    "ag-grid-community": ">=35.0.0",
    "ag-grid-react": ">=35.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-select": "^2.1.6",
    "clsx": "^2.1.1",
    "lucide-react": "^0.546.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "ag-grid-community": "^35.2.1",
    "ag-grid-react": "^35.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vite": "^8.1.3"
  }
}
